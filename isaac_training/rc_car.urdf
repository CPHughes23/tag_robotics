<?xml version="1.0"?>
<robot name="rc_car">

  <!-- Chassis -->
  <link name="chassis">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" iyy="0.02" izz="0.02" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.07"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.3 0.15 0.07"/>
      </geometry>
    </collision>
  </link>

  <!-- Rear Left Wheel -->
  <link name="rear_left_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.12 0.09 -0.03" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Rear Right Wheel -->
  <link name="rear_right_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.12 -0.09 -0.03" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Front Left Steer Link (intermediate link between chassis and front left wheel) -->
  <link name="front_left_steer_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_left_steer_joint" type="revolute">
    <parent link="chassis"/>
    <child link="front_left_steer_link"/>
    <origin xyz="0.12 0.09 -0.03" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10.0" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <!-- Front Left Wheel -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Front Right Steer Link (intermediate link between chassis and front right wheel) -->
  <link name="front_right_steer_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="front_right_steer_joint" type="revolute">
    <parent link="chassis"/>
    <child link="front_right_steer_link"/>
    <origin xyz="0.12 -0.09 -0.03" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10.0" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <!-- Front Right Wheel -->
  <link name="front_right_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

</robot>